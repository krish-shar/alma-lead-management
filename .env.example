# ============================================================================
#  Alma Lead Management — environment configuration
#  Copy to `.env` (git-ignored) and adjust. The committed defaults below are the
#  working LOCAL (Docker Compose) values; the inline notes mark what changes for
#  a hosted (Supabase/Vercel/Render/Resend) deploy. See docs/DESIGN.md.
# ============================================================================

# --- Postgres (consumed by the `db` service + DATABASE_URL below) ---
POSTGRES_USER=alma
POSTGRES_PASSWORD=alma
POSTGRES_DB=alma

# --- Database (backend + Better Auth both connect here) ---
# Local: host is the compose service name `db`. Hosted: Supabase connection string.
DATABASE_URL=postgresql+psycopg://alma:alma@db:5432/alma
# Better Auth (Node) uses a non-SQLAlchemy URL form:
BETTER_AUTH_DATABASE_URL=postgresql://alma:alma@db:5432/alma

# --- Object storage (S3-compatible) ---
# Two endpoints on purpose: internal for backend traffic, public for presigned URLs
# the browser opens (a presigned URL is bound to the host it was signed with).
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=resumes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path        # "path" for MinIO, "virtual" for Supabase
RESUME_URL_TTL_SECONDS=300
MAX_RESUME_BYTES=4194304        # 4 MB

# --- Email ---
EMAIL_PROVIDER=smtp             # "smtp" (Mailpit, local) | "resend" (hosted, verified domain)
EMAIL_FROM=Alma Recruiting <noreply@alma.test>
ATTORNEY_EMAIL=attorney@alma.test
SMTP_HOST=mailpit
SMTP_PORT=1025
RESEND_API_KEY=                 # set for EMAIL_PROVIDER=resend
PUBLIC_APP_URL=http://localhost:3000   # used to build the attorney email's dashboard link

# --- Auth (FastAPI verifies Better Auth's EdDSA JWTs via JWKS) ---
# JWKS_URL = where FastAPI FETCHES keys (internal Docker host).
# ISSUER/AUDIENCE = what the token CARRIES (the browser-facing Better Auth URL).
JWT_JWKS_URL=http://frontend:3000/api/auth/jwks
JWT_ISSUER=http://localhost:3000
JWT_AUDIENCE=http://localhost:3000
JWT_ALGORITHMS=EdDSA

# --- CORS (backend allows the frontend origin; comma-separated for multiple) ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Better Auth (Next.js) ---
BETTER_AUTH_SECRET=dev-only-change-me-please-32chars-min
BETTER_AUTH_URL=http://localhost:3000

# --- Frontend (browser → backend) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Attorney seed (created via Better Auth API by `make seed`) ---
SEED_ATTORNEY_EMAIL=attorney@alma.test
SEED_ATTORNEY_PASSWORD=password123
SEED_ATTORNEY_NAME=Alma Attorney
